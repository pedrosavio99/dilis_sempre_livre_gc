# Neon PostgreSQL connection string
# Obtenha em: https://console.neon.tech → seu projeto → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require

# JWT secret (troque por uma string longa e aleatória)
JWT_SECRET=troque_por_algo_secreto_e_longo

# Credenciais do admin (login na tela administrativa)
ADMIN_USERNAME=admin
ADMIN_PIN=1234

# Origem permitida para CORS (opcional — deixe * para qualquer)
# ALLOWED_ORIGIN=https://seudominio.netlify.app

# URL base da API — usado pelo Vite no build
# Em produção no Netlify, deixe como /api (o redirect cuida do resto)
# VITE_API_URL=/api
